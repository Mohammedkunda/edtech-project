{
  "name": "localfirst-editor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "pnpm build:packages",
    "build:packages": "pnpm --filter @localfirst/shared build && pnpm --filter @localfirst/db build",
    "dev": "pnpm build:packages && pnpm --filter web dev",
    "dev:ws": "pnpm build:packages && pnpm --filter ws-server dev",
    "dev:all": "pnpm build:packages && pnpm --filter web --filter ws-server --parallel dev",
    "build": "pnpm -r --filter=!ws-server build && pnpm --filter ws-server build",
    "start": "pnpm --filter web start",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @localfirst/db prisma generate",
    "db:migrate": "pnpm --filter @localfirst/db prisma migrate dev",
    "db:push": "pnpm --filter @localfirst/db prisma db push",
    "db:studio": "pnpm --filter @localfirst/db prisma studio"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@10.34.1",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
