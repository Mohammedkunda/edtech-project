# ---- Database (PostgreSQL) ----
# Used by Prisma (packages/db) and the web app at runtime.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/localfirst?schema=public"

# ---- NextAuth (Auth.js, Milestone 2) ----
# Generate with:  openssl rand -base64 32
AUTH_SECRET="change-me"
NEXTAUTH_URL="http://localhost:3000"

# ---- WebSocket sync server ----
# URL the browser client connects to (must be reachable from the browser).
NEXT_PUBLIC_WS_URL="ws://localhost:8080"
# Port the WS server listens on.
WS_PORT=8080
# Secret used to sign/verify sync-session JWTs (may equal AUTH_SECRET).
JWT_SECRET="change-me"

# ---- AI bonus (optional, Milestone 9) ----
# GROQ_API_KEY=""
